{
  "manifest_version": 3,
  "name": "noddle",
  "version": "0.1.5",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.toddleapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ]
}